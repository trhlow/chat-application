###
GET http://localhost:8080/api/messages?roomId=REPLACE_ROOM_ID&limit=20&before=2026-04-07T10:00:00
Authorization: Bearer REPLACE_ACCESS_TOKEN

###
POST http://localhost:8080/api/messages
Content-Type: application/json
Authorization: Bearer REPLACE_ACCESS_TOKEN

{
  "roomId": "REPLACE_ROOM_ID",
  "content": "Xin chao, day la tin nhan moi"
}

###
POST http://localhost:8080/api/messages/attachments
Authorization: Bearer REPLACE_ACCESS_TOKEN
Content-Type: multipart/form-data; boundary=messageAttachmentBoundary

--messageAttachmentBoundary
Content-Disposition: form-data; name="roomId"

REPLACE_ROOM_ID
--messageAttachmentBoundary
Content-Disposition: form-data; name="content"

Tin nhan kem file
--messageAttachmentBoundary
Content-Disposition: form-data; name="file"; filename="sample.png"
Content-Type: image/png

< ./sample.png
--messageAttachmentBoundary--

###
PATCH http://localhost:8080/api/messages/REPLACE_MESSAGE_ID/status
Content-Type: application/json
Authorization: Bearer REPLACE_ACCESS_TOKEN

{
  "status": "read"
}
