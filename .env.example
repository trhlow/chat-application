APP_JWT_REFRESH_EXPIRATION_MS=604800000
APP_STORAGE_PROVIDER=local
APP_STORAGE_LOCAL_UPLOAD_DIR=uploads/avatars
APP_MESSAGE_ATTACHMENT_LOCAL_UPLOAD_DIR=uploads/message-attachments
APP_PUBLIC_BASE_URL=http://localhost:8080
